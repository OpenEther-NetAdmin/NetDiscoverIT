flowchart TB
    subgraph Customer_Network["Customer Network (On-Premises)"]
        direction TB
        Devices["Network Devices<br/>(Routers, Switches, Firewalls)"]
        Agent["Local Agent<br/>(Docker Container)"]
        
        Devices --> Agent
    end
    
    subgraph Agent_Service["Agent Service"]
        direction LR
        
        Scanner["scanner.py<br/>Network Discovery"]
        Collector["collector.py<br/>Config Collection"]
        Sanitizer["sanitizer.py<br/>PII/Credential Stripping"]
        Topology["topology.py<br/>Topology Mapping"]
        Vectorizer["vectorizer.py<br/>Embedding Generation"]
        Uploader["uploader.py<br/>Metadata Upload"]
        
        Scanner --> Collector
        Collector --> Sanitizer
        Sanitizer --> Topology
        Topology --> Vectorizer
        Vectorizer --> Uploader
    end
    
    subgraph Cloud["Cloud Platform"]
        direction LR
        
        API["FastAPI<br/>(:8000)"]
        Postgres["PostgreSQL<br/>(+pgvector)"]
        Neo4j["Neo4j<br/>(Graph)"]
        Frontend["React Frontend<br/>(:3000)"]
        
        API --> Postgres
        API --> Neo4j
        API --> Frontend
    end
    
    Agent -->|HTTPS + JWT| API
    Uploader -->|Sanitized Data| API
    
    style Customer_Network fill:#f3f4f6,stroke:#374151,stroke-width:2px
    style Agent_Service fill:#e0e7ff,stroke:#4f46e5,stroke-width:2px
    style Cloud fill:#d1fae5,stroke:#059669,stroke-width:2px