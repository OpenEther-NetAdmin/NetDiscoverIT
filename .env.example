# =============================================================================
# NetDiscoverIT Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!
# =============================================================================

# =============================================================================
# APPLICATION
# =============================================================================
APP_NAME=NetDiscoverIT
APP_VERSION=0.1.0
APP_ENV=development  # development | staging | production
APP_DEBUG=true
APP_URL=http://localhost:3000
APP_API_URL=http://localhost:8000

# =============================================================================
# DATABASE
# =============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=netdiscoverit
POSTGRES_USER=netdiscoverit
POSTGRES_PASSWORD=changeme
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10

# =============================================================================
# REDIS
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# NEO4J (Graph Database for Topology)
# =============================================================================
NEO4J_HOST=neo4j
NEO4J_PORT=7687
NEO4J_HTTP_PORT=7474
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j

# =============================================================================
# VAULT (HashiCorp Vault for secrets)
# =============================================================================
VAULT_ENABLED=true
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=changeme
VAULT_SECRET_PATH=secret/data/netdiscoverit

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
JWT_SECRET_KEY=changeme-super-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# API KEYS
# =============================================================================
# Internal service-to-service API key
INTERNAL_API_KEY=changeme-internal-api-key

# =============================================================================
# CLOUD LLM PROVIDERS
# =============================================================================
# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Google Gemini
GOOGLE_API_KEY=

# Ollama (local)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:7b

# =============================================================================
# LOCAL AGENT
# =============================================================================
AGENT_API_ENDPOINT=https://api.netdiscoverit.com
AGENT_SCAN_INTERVAL=24h
AGENT_LOG_LEVEL=info
AGENT_DISCOVERY_METHODS=ssh,snmp,nmap,cdp,lldp,netflow
AGENT_SSH_TIMEOUT=30
AGENT_SSH_RETRY=3
AGENT_SNMP_TIMEOUT=5
AGENT_NMAP_TIMEOUT=60

# =============================================================================
# VECTOR DATABASE
# =============================================================================
VECTOR_DB_PROVIDER=pgvector  # pgvector | pinecone | weaviate
VECTOR_DIMENSION=768

# Pinecone (if using)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX=netdiscoverit

# =============================================================================
# FRONTEND
# =============================================================================
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000
REACT_APP_ENV=development

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info
LOG_FORMAT=json  # json | text

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# =============================================================================
# EMAIL (SMTP)
# =============================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@netdiscoverit.com

# =============================================================================
# NETBOX INTEGRATION (Optional)
# =============================================================================
NETBOX_URL=
NETBOX_API_KEY=

# =============================================================================
# MONITORING
# =============================================================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# =============================================================================
# SECURITY
# =============================================================================
ALLOWED_HOSTS=localhost,127.0.0.1
SECRET_KEY=changeme-super-secret-key-min-32-chars
